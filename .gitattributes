* text=auto

# Shell and Linux deployment files must stay LF-only. CRLF breaks shebangs
# and can make bash read options such as "pipefail\r".
*.sh text eol=lf
deploy.sh text eol=lf
config/linux/*.env.example text eol=lf
templates/linux/* text eol=lf
ansible/roles/linux_node_service/templates/* text eol=lf

# Windows entrypoints are intentionally CRLF-friendly.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
