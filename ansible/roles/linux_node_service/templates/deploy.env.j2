# Generic app identity
APP_NAME={{ node_deploy_project_name | quote }}
APP_DISPLAY_NAME={{ node_deploy_display_name | quote }}
APP_DESCRIPTION={{ node_deploy_description | default(node_deploy_display_name ~ ' production service') | quote }}

# Deployment selections
DEPLOYMENT_MODE={{ node_deploy_mode | quote }}
APP_RUNTIME={{ node_deploy_app_runtime | default('node') | quote }}
SERVICE_MANAGER={{ node_deploy_linux_service_manager | quote }}
REVERSE_PROXY={{ node_deploy_linux_reverse_proxy | quote }}
SKIP_PREFLIGHT={{ (node_deploy_skip_preflight | default(false) | bool | ternary('true', 'false')) | quote }}
ALLOW_PORT_IN_USE={{ (node_deploy_allow_port_in_use | default(false) | bool | ternary('true', 'false')) | quote }}
SKIP_REVERSE_PROXY={{ (node_deploy_skip_reverse_proxy | default(false) | bool | ternary('true', 'false')) | quote }}
SKIP_HEALTH_CHECK={{ (((node_deploy_skip_health_check | default(false) | bool) or not (node_deploy_healthcheck_enabled | default(true) | bool)) | ternary('true', 'false')) | quote }}

# Runtime
APP_DIR={{ node_deploy_app_dir_linux | quote }}
NODE_BIN={{ node_deploy_linux_node_bin | quote }}
START_SCRIPT={{ node_deploy_start_script | quote }}
NODE_ARGUMENTS={{ node_deploy_node_arguments | default('') | quote }}
INSTALL_COMMAND={{ node_deploy_install_command | default('') | quote }}
BUILD_COMMAND={{ node_deploy_build_command | default('') | quote }}
SKIP_INSTALL={{ (node_deploy_skip_install | default(false) | bool | ternary('true', 'false')) | quote }}
SKIP_BUILD={{ (node_deploy_skip_build | default(false) | bool | ternary('true', 'false')) | quote }}
{% set runtime_environment = node_deploy_environment | default({}) %}
NODE_ENV={{ runtime_environment.NODE_ENV | default('production') | quote }}
APP_PORT={{ node_deploy_port | string | quote }}
BIND_ADDRESS={{ node_deploy_bind_address | quote }}
HEALTH_URL={{ node_deploy_health_url | quote }}
{% set default_runtime_keys = [] %}
{% for key in runtime_environment.keys() %}
{% if key not in ['NODE_ENV', 'PORT', 'APP_PORT', 'APP_NAME', 'BIND_ADDRESS'] %}
{% set _ = default_runtime_keys.append(key) %}
{% endif %}
{% endfor %}
{% set runtime_keys = node_deploy_linux_runtime_env_keys | default(default_runtime_keys) %}
{% if runtime_keys | length == 0 %}
{% set runtime_keys = default_runtime_keys %}
{% endif %}
RUNTIME_ENV_KEYS={{ (runtime_keys | join(' ')) | quote }}
{% for key, value in runtime_environment.items() %}
{{ key }}={{ value | string | quote }}
{% endfor %}

# Service user and logs
SERVICE_USER={{ node_deploy_linux_service_user | quote }}
SERVICE_GROUP={{ node_deploy_linux_service_group | quote }}
LOG_DIR={{ node_deploy_linux_log_dir | quote }}
ENV_FILE={{ node_deploy_linux_env_file | quote }}
BACKUP_DIR={{ node_deploy_linux_backup_dir | default('/var/backups/' ~ node_deploy_project_name) | quote }}

# Reverse proxy
PUBLIC_HOSTNAME={{ node_deploy_public_hostname | quote }}
PUBLIC_PORT={{ node_deploy_public_port | default(443) | string | quote }}
TLS_ENABLED={{ (node_deploy_tls_enabled | default(true) | bool | ternary('true', 'false')) | quote }}
NGINX_SITE_NAME={{ node_deploy_linux_nginx_site_name | default(node_deploy_project_name) | quote }}
NGINX_CONFIG_DIR={{ node_deploy_linux_nginx_config_dir | default('') | quote }}
NGINX_SERVICE={{ node_deploy_linux_nginx_service | default('nginx') | quote }}
APACHE_SITE_NAME={{ node_deploy_linux_apache_site_name | default(node_deploy_project_name) | quote }}
APACHE_CONFIG_DIR={{ node_deploy_linux_apache_config_dir | default('') | quote }}
APACHE_SERVICE={{ node_deploy_linux_apache_service | default('') | quote }}
HAPROXY_CONFIG_FILE={{ node_deploy_linux_haproxy_config_file | default('/etc/haproxy/haproxy.cfg') | quote }}
HAPROXY_BIND={{ node_deploy_linux_haproxy_bind | default('*:80') | quote }}
HAPROXY_FRONTEND_NAME={{ node_deploy_linux_haproxy_frontend_name | default(node_deploy_project_name ~ '_frontend') | quote }}
HAPROXY_BACKEND_NAME={{ node_deploy_linux_haproxy_backend_name | default(node_deploy_project_name ~ '_backend') | quote }}
HAPROXY_SERVICE={{ node_deploy_linux_haproxy_service | default('haproxy') | quote }}
TRAEFIK_DYNAMIC_DIR={{ node_deploy_linux_traefik_dynamic_dir | default('/etc/traefik/dynamic') | quote }}
TRAEFIK_DYNAMIC_FILE={{ node_deploy_linux_traefik_dynamic_file | default('/etc/traefik/dynamic/' ~ node_deploy_project_name ~ '.yml') | quote }}
TRAEFIK_ENTRYPOINT={{ node_deploy_linux_traefik_entrypoint | default('web') | quote }}
TRAEFIK_ROUTER_NAME={{ node_deploy_linux_traefik_router_name | default(node_deploy_project_name ~ '-router') | quote }}
TRAEFIK_SERVICE_NAME={{ node_deploy_linux_traefik_service_name | default(node_deploy_project_name ~ '-service') | quote }}
TRAEFIK_SERVICE={{ node_deploy_linux_traefik_service | default('traefik') | quote }}
HEALTHCHECK_PATH={{ node_deploy_linux_healthcheck_path | default('/health') | quote }}

# Tomcat runtime mode
TOMCAT_PACKAGE={{ node_deploy_tomcat_package | default('') | quote }}
TOMCAT_SERVICE={{ node_deploy_tomcat_service | default('tomcat') | quote }}
TOMCAT_WEBAPPS_DIR={{ node_deploy_tomcat_webapps_dir | default('/var/lib/tomcat/webapps') | quote }}
TOMCAT_WAR_FILE={{ node_deploy_tomcat_war_file | default('') | quote }}
TOMCAT_CONTEXT_PATH={{ node_deploy_tomcat_context_path | default('/' ~ node_deploy_project_name) | quote }}
TOMCAT_RESTART={{ (node_deploy_tomcat_restart | default(true) | bool | ternary('true', 'false')) | quote }}

# Package overrides
NGINX_PACKAGE={{ node_deploy_linux_nginx_package | default('nginx') | quote }}
APACHE_PACKAGE={{ node_deploy_linux_apache_package | default('') | quote }}
HAPROXY_PACKAGE={{ node_deploy_linux_haproxy_package | default('haproxy') | quote }}
TRAEFIK_PACKAGE={{ node_deploy_linux_traefik_package | default('traefik') | quote }}

# Health check
HEALTHCHECK_INTERVAL={{ node_deploy_healthcheck_interval | default(60) | string | quote }}
HEALTHCHECK_FAILURE_THRESHOLD={{ node_deploy_healthcheck_failure_threshold | default(2) | string | quote }}
HEALTHCHECK_RESTART_COOLDOWN={{ node_deploy_healthcheck_restart_cooldown_seconds | default((node_deploy_healthcheck_restart_cooldown_minutes | default(5) | int) * 60) | string | quote }}
HEALTHCHECK_TIMEOUT={{ node_deploy_healthcheck_timeout_seconds | default(10) | string | quote }}
FAILURE_RESTART_DELAY={{ node_deploy_failure_restart_delay_seconds | default(60) | string | quote }}
LOG_RETENTION_DAYS={{ node_deploy_log_retention_days | default(30) | string | quote }}
BACKUP_RETENTION_DAYS={{ node_deploy_backup_retention_days | default(90) | string | quote }}
DIAGNOSTIC_RETENTION_DAYS={{ node_deploy_diagnostic_retention_days | default(14) | string | quote }}
