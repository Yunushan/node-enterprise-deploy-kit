# Generic app identity
APP_NAME="example-node-app"
APP_DISPLAY_NAME="Example Node App"
APP_DESCRIPTION="Example Node.js production service"

# Deployment selections
DEPLOYMENT_MODE="reverse_proxy"
APP_RUNTIME="node"
SERVICE_MANAGER="systemd"
REVERSE_PROXY="nginx"
SKIP_PREFLIGHT="false"
ALLOW_PORT_IN_USE="false"
SKIP_REVERSE_PROXY="false"
SKIP_HEALTH_CHECK="false"

# Runtime
APP_DIR="/opt/example-node-app"
NODE_BIN="/usr/bin/node"
START_SCRIPT="server.js"
NODE_ARGUMENTS=""
INSTALL_COMMAND="npm ci --omit=dev"
BUILD_COMMAND="npm run build"
SKIP_INSTALL="false"
SKIP_BUILD="false"
NODE_ENV="production"
APP_PORT="3000"
BIND_ADDRESS="127.0.0.1"
HEALTH_URL="http://127.0.0.1:3000/health"
RUNTIME_ENV_KEYS=""

# Service user and logs
SERVICE_USER="nodeapp"
SERVICE_GROUP="nodeapp"
LOG_DIR="/var/log/example-node-app"
ENV_FILE="/etc/example-node-app/example-node-app.env"
BACKUP_DIR="/var/backups/example-node-app"

# Reverse proxy
PUBLIC_HOSTNAME="app.example.local"
PUBLIC_PORT="443"
TLS_ENABLED="true"
NGINX_SITE_NAME="example-node-app"
NGINX_CONFIG_DIR=""
NGINX_SERVICE="nginx"
APACHE_SITE_NAME="example-node-app"
APACHE_CONFIG_DIR=""
APACHE_SERVICE=""
HAPROXY_CONFIG_FILE="/etc/haproxy/haproxy.cfg"
HAPROXY_BIND="*:80"
HAPROXY_FRONTEND_NAME="example-node-app_frontend"
HAPROXY_BACKEND_NAME="example-node-app_backend"
HAPROXY_SERVICE="haproxy"
TRAEFIK_DYNAMIC_DIR="/etc/traefik/dynamic"
TRAEFIK_DYNAMIC_FILE="/etc/traefik/dynamic/example-node-app.yml"
TRAEFIK_ENTRYPOINT="web"
TRAEFIK_ROUTER_NAME="example-node-app-router"
TRAEFIK_SERVICE_NAME="example-node-app-service"
TRAEFIK_SERVICE="traefik"
HEALTHCHECK_PATH="/health"

# Tomcat runtime mode; used only when APP_RUNTIME="tomcat"
TOMCAT_PACKAGE=""
TOMCAT_SERVICE="tomcat"
TOMCAT_WEBAPPS_DIR="/var/lib/tomcat/webapps"
TOMCAT_WAR_FILE=""
TOMCAT_CONTEXT_PATH="/example-node-app"
TOMCAT_RESTART="true"

# Package overrides for scripts/linux/install-dependencies.sh
NGINX_PACKAGE="nginx"
APACHE_PACKAGE=""
HAPROXY_PACKAGE="haproxy"
TRAEFIK_PACKAGE="traefik"

# Health check
HEALTHCHECK_INTERVAL="60"
HEALTHCHECK_FAILURE_THRESHOLD="2"
HEALTHCHECK_RESTART_COOLDOWN="300"
HEALTHCHECK_TIMEOUT="10"
HEALTHCHECK_STATE_DIR="/var/lib/node-enterprise-deploy-kit/example-node-app"
FAILURE_RESTART_DELAY="60"
LOG_RETENTION_DAYS="30"
BACKUP_RETENTION_DAYS="90"
DIAGNOSTIC_RETENTION_DAYS="14"
