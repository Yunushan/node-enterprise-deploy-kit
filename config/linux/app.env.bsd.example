# Generic app identity
APP_NAME="example-next-bsd"
APP_DISPLAY_NAME="Example Next.js BSD App"
APP_DESCRIPTION="Example Next.js service managed by BSD rc"

# Deployment selections
DEPLOYMENT_MODE="reverse_proxy"
APP_FRAMEWORK="nextjs"
NEXTJS_DEPLOYMENT_MODE="standalone"
REACT_DOCUMENT_ROOT="build"
NEXTJS_REQUIRE_STATIC_ASSETS="true"
NEXTJS_REQUIRE_PUBLIC_DIR="false"
NEXTJS_REQUIRE_SERVER_ACTIONS_ENCRYPTION_KEY="false"
NEXTJS_REQUIRE_DEPLOYMENT_ID="false"
NEXTJS_MINIMUM_NODE_VERSION="20.9.0"
APP_RUNTIME="node"
SERVICE_MANAGER="bsdrc"
REVERSE_PROXY="nginx"
SKIP_PREFLIGHT="false"
ALLOW_PORT_IN_USE="false"
SKIP_REVERSE_PROXY="false"
SKIP_HEALTH_CHECK="false"

# Runtime
APP_DIR="/usr/local/www/example-next-bsd"
DEPLOYMENT_ID=""
PACKAGE_PATH=""
PACKAGE_EXPECTED_FILES="server.js .next/BUILD_ID .next/static node_modules/next/package.json"
PACKAGE_STRIP_SINGLE_TOP_LEVEL_DIR="true"
SKIP_PACKAGE_IMPORT="false"
NODE_BIN="/usr/local/bin/node"
START_SCRIPT="server.js"
NODE_ARGUMENTS=""
INSTALL_COMMAND="npm ci --omit=dev"
BUILD_COMMAND="npm run build"
SKIP_INSTALL="false"
SKIP_BUILD="false"
NODE_ENV="production"
APP_PORT="3000"
BIND_ADDRESS="127.0.0.1"
HEALTH_URL="http://127.0.0.1:3000/health"
RUNTIME_ENV_KEYS=""

# Service user and logs
SERVICE_USER="nodeapp"
SERVICE_GROUP="nodeapp"
LOG_DIR="/var/log/example-next-bsd"
ENV_FILE="/usr/local/etc/example-next-bsd/example-next-bsd.env"
BACKUP_DIR="/var/backups/example-next-bsd"

# Reverse proxy
PUBLIC_HOSTNAME="app.example.local"
PUBLIC_PORT="443"
TLS_ENABLED="true"
PROXY_LISTEN_PORT="80"
FORWARDED_PROTO="https"
FORWARDED_PORT="443"
PROXY_HEALTH_URL=""
NGINX_SITE_NAME="example-next-bsd"
NGINX_CONFIG_DIR="/usr/local/etc/nginx/conf.d"
NGINX_SERVICE="nginx"
APACHE_SITE_NAME="example-next-bsd"
APACHE_CONFIG_DIR="/usr/local/etc/apache24/Includes"
APACHE_SERVICE="apache24"
HAPROXY_CONFIG_FILE="/usr/local/etc/haproxy/haproxy.cfg"
HAPROXY_ALLOW_MAIN_CONFIG_REPLACE="false"
HAPROXY_BIND="*:80"
HAPROXY_FRONTEND_NAME="example_next_bsd_frontend"
HAPROXY_BACKEND_NAME="example_next_bsd_backend"
HAPROXY_SERVICE="haproxy"
TRAEFIK_DYNAMIC_DIR="/usr/local/etc/traefik/dynamic"
TRAEFIK_DYNAMIC_FILE="/usr/local/etc/traefik/dynamic/example-next-bsd.yml"
TRAEFIK_ENTRYPOINT="web"
TRAEFIK_ROUTER_NAME="example-next-bsd-router"
TRAEFIK_SERVICE_NAME="example-next-bsd-service"
TRAEFIK_SERVICE="traefik"
HEALTHCHECK_PATH="/health"

# Tomcat runtime mode; used only when APP_RUNTIME="tomcat"
TOMCAT_PACKAGE=""
TOMCAT_SERVICE="tomcat"
TOMCAT_WEBAPPS_DIR="/usr/local/apache-tomcat-10.1/webapps"
TOMCAT_WAR_FILE=""
TOMCAT_CONTEXT_PATH="/example-next-bsd"
TOMCAT_RESTART="true"

# Package overrides for scripts/linux/install-dependencies.sh
NGINX_PACKAGE="nginx"
APACHE_PACKAGE="apache24"
HAPROXY_PACKAGE="haproxy"
TRAEFIK_PACKAGE="traefik"
UNZIP_PACKAGE="unzip"

# Health check
HEALTHCHECK_INTERVAL="60"
HEALTHCHECK_FAILURE_THRESHOLD="2"
HEALTHCHECK_RESTART_COOLDOWN="300"
HEALTHCHECK_TIMEOUT="10"
HEALTHCHECK_STATE_DIR="/var/db/node-enterprise-deploy-kit/example-next-bsd"
FAILURE_RESTART_DELAY="60"
LOG_RETENTION_DAYS="30"
BACKUP_RETENTION_DAYS="90"
DIAGNOSTIC_RETENTION_DAYS="14"
