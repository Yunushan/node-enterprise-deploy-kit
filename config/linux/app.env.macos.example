# Generic app identity
APP_NAME="example-next-macos"
APP_DISPLAY_NAME="Example Next.js macOS App"
APP_DESCRIPTION="Example Next.js service managed by launchd"

# Deployment selections
DEPLOYMENT_MODE="reverse_proxy"
APP_FRAMEWORK="nextjs"
NEXTJS_DEPLOYMENT_MODE="standalone"
REACT_DOCUMENT_ROOT="build"
NEXTJS_REQUIRE_STATIC_ASSETS="true"
NEXTJS_REQUIRE_PUBLIC_DIR="false"
NEXTJS_REQUIRE_SERVER_ACTIONS_ENCRYPTION_KEY="false"
NEXTJS_REQUIRE_DEPLOYMENT_ID="false"
NEXTJS_MINIMUM_NODE_VERSION="20.9.0"
APP_RUNTIME="node"
SERVICE_MANAGER="launchd"
REVERSE_PROXY="nginx"
SKIP_PREFLIGHT="false"
ALLOW_PORT_IN_USE="false"
SKIP_REVERSE_PROXY="false"
SKIP_HEALTH_CHECK="false"

# Runtime
APP_DIR="/usr/local/var/node-enterprise-deploy-kit/example-next-macos"
DEPLOYMENT_ID=""
PACKAGE_PATH=""
PACKAGE_EXPECTED_FILES="server.js .next/BUILD_ID .next/static"
PACKAGE_STRIP_SINGLE_TOP_LEVEL_DIR="true"
SKIP_PACKAGE_IMPORT="false"
NODE_BIN="/opt/homebrew/bin/node"
START_SCRIPT="server.js"
NODE_ARGUMENTS=""
INSTALL_COMMAND="npm ci --omit=dev"
BUILD_COMMAND="npm run build"
SKIP_INSTALL="false"
SKIP_BUILD="false"
NODE_ENV="production"
APP_PORT="3000"
BIND_ADDRESS="127.0.0.1"
HEALTH_URL="http://127.0.0.1:3000/health"
RUNTIME_ENV_KEYS=""

# Service user and logs
SERVICE_USER="_www"
SERVICE_GROUP="_www"
LOG_DIR="/usr/local/var/log/example-next-macos"
ENV_FILE="/usr/local/etc/example-next-macos/example-next-macos.env"
BACKUP_DIR="/usr/local/var/backups/example-next-macos"
RUNNER_SCRIPT="/usr/local/sbin/example-next-macos-runner.sh"

# Reverse proxy
PUBLIC_HOSTNAME="app.example.local"
PUBLIC_PORT="443"
TLS_ENABLED="true"
PROXY_LISTEN_PORT="80"
FORWARDED_PROTO="https"
FORWARDED_PORT="443"
PROXY_HEALTH_URL=""
NGINX_SITE_NAME="example-next-macos"
NGINX_CONFIG_DIR=""
NGINX_SERVICE="nginx"
APACHE_SITE_NAME="example-next-macos"
APACHE_CONFIG_DIR=""
APACHE_SERVICE="httpd"
HAPROXY_CONFIG_FILE="/opt/homebrew/etc/haproxy/haproxy.cfg"
HAPROXY_ALLOW_MAIN_CONFIG_REPLACE="false"
HAPROXY_BIND="*:80"
HAPROXY_FRONTEND_NAME="example_next_macos_frontend"
HAPROXY_BACKEND_NAME="example_next_macos_backend"
HAPROXY_SERVICE="haproxy"
TRAEFIK_DYNAMIC_DIR="/opt/homebrew/etc/traefik/dynamic"
TRAEFIK_DYNAMIC_FILE="/opt/homebrew/etc/traefik/dynamic/example-next-macos.yml"
TRAEFIK_ENTRYPOINT="web"
TRAEFIK_ROUTER_NAME="example-next-macos-router"
TRAEFIK_SERVICE_NAME="example-next-macos-service"
TRAEFIK_SERVICE="traefik"
HEALTHCHECK_PATH="/health"

# Tomcat runtime mode; used only when APP_RUNTIME="tomcat"
TOMCAT_PACKAGE=""
TOMCAT_SERVICE="tomcat"
TOMCAT_WEBAPPS_DIR="/usr/local/var/tomcat/webapps"
TOMCAT_WAR_FILE=""
TOMCAT_CONTEXT_PATH="/example-next-macos"
TOMCAT_RESTART="true"

# Package overrides for scripts/linux/install-dependencies.sh
NGINX_PACKAGE="nginx"
APACHE_PACKAGE="httpd"
HAPROXY_PACKAGE="haproxy"
TRAEFIK_PACKAGE="traefik"
UNZIP_PACKAGE="unzip"

# Health check
HEALTHCHECK_INTERVAL="60"
HEALTHCHECK_FAILURE_THRESHOLD="2"
HEALTHCHECK_RESTART_COOLDOWN="300"
HEALTHCHECK_TIMEOUT="10"
HEALTHCHECK_STATE_DIR="/usr/local/var/lib/node-enterprise-deploy-kit/example-next-macos"
FAILURE_RESTART_DELAY="60"
LOG_RETENTION_DAYS="30"
BACKUP_RETENTION_DAYS="90"
DIAGNOSTIC_RETENTION_DAYS="14"
