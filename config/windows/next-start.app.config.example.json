{
  "AppName": "ExampleNextStartApp",
  "DisplayName": "Example Next.js Next Start App",
  "Description": "Example Next.js next-start production service",
  "DeploymentMode": "reverse_proxy",
  "AppFramework": "nextjs",
  "NextjsDeploymentMode": "next-start",
  "ReactDocumentRoot": "build",
  "NextjsRequireStaticAssets": false,
  "NextjsRequirePublicDirectory": false,
  "NextjsRequireServerActionsEncryptionKey": false,
  "NextjsRequireDeploymentId": false,
  "NextjsMinimumNodeVersion": "20.9.0",
  "ServiceManager": "winsw",
  "ReverseProxy": "iis",
  "AutoDownloadWinSW": true,
  "WinSWDownloadUrl": "https://github.com/winsw/winsw/releases/download/v2.12.0/WinSW-x64.exe",
  "RequireWinSWDownloadSha256": true,
  "WinSWDownloadSha256": "05B82D46AD331CC16BDC00DE5C6332C1EF818DF8CEEFCD49C726553209B3A0DA",
  "AppDirectory": "C:\\apps\\ExampleNextStartApp",
  "PackagePath": "",
  "PackageExpectedFiles": [
    "package.json",
    ".next",
    ".next/BUILD_ID",
    "node_modules/next/package.json",
    "node_modules/next/dist/bin/next"
  ],
  "PackageStripSingleTopLevelDirectory": true,
  "DeploymentId": "",
  "StartCommand": "node_modules\\next\\dist\\bin\\next",
  "NodeExe": "C:\\Program Files\\nodejs\\node.exe",
  "NodeArguments": "start -H 127.0.0.1",
  "InstallCommand": "npm ci --omit=dev",
  "BuildCommand": "npm run build",
  "Port": 3000,
  "BindAddress": "127.0.0.1",
  "HealthUrl": "http://127.0.0.1:3000/health",
  "ProxyHealthUrl": "",
  "HealthCheckIntervalMinutes": 1,
  "ServiceDirectory": "C:\\services\\ExampleNextStartApp",
  "LogDirectory": "C:\\logs\\ExampleNextStartApp",
  "BackupDirectory": "C:\\services\\ExampleNextStartApp\\backups",
  "IisSitePath": "C:\\inetpub\\wwwroot\\ExampleNextStartApp",
  "IisSiteName": "ExampleNextStartApp",
  "IisAppPoolName": "ExampleNextStartApp-AppPool",
  "PublicHostName": "app.example.local",
  "PublicPort": 443,
  "TlsEnabled": true,
  "IisCertificateThumbprint": "",
  "IisEnableArrProxy": true,
  "IisRequireUrlRewrite": true,
  "IisRequireArrProxy": true,
  "IisSetForwardedHeaders": true,
  "IisHealthProxyPath": "health",
  "IisWebSocketSupport": true,
  "IisProxyTimeoutSeconds": 300,
  "ServiceAccount": "NetworkService",
  "ServiceAccountPassword": "",
  "FailureRestartDelaySeconds": 60,
  "HealthCheckFailureThreshold": 2,
  "HealthCheckRestartCooldownMinutes": 5,
  "HealthCheckTimeoutSeconds": 10,
  "LogRetentionDays": 30,
  "BackupRetentionDays": 90,
  "DiagnosticRetentionDays": 14,
  "Environment": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "APP_PORT": "3000",
    "APP_NAME": "ExampleNextStartApp",
    "BIND_ADDRESS": "127.0.0.1",
    "HOST": "127.0.0.1",
    "HOSTNAME": "127.0.0.1"
  }
}
